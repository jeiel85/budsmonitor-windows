<Window x:Class="BudsMonitor.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BudsMonitor.App"
        mc:Ignorable="d"
        Title="설정 - BudsMonitor"
        Height="620" Width="480"
        MinHeight="440" MinWidth="440"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource CanvasSoftBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Text="설정" Style="{StaticResource Heading2}" />
            <TextBlock Text="테마·시작·알림·개인정보 옵션을 관리합니다."
                       Style="{StaticResource Caption}" Margin="0,4,0,20" TextWrapping="Wrap" />

            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="일반" Style="{StaticResource Title}" Margin="0,0,0,12" />
                    <StackPanel>
                        <CheckBox x:Name="StartWithWindowsCheckBox" Content="Windows 시작 시 실행" Margin="0,5"
                                  Checked="OnStartWithWindowsChanged" Unchecked="OnStartWithWindowsChanged" />
                        <CheckBox x:Name="MinimizeToTrayCheckBox" Content="트레이로 최소화" Margin="0,5"
                                  Checked="OnMinimizeToTrayChanged" Unchecked="OnMinimizeToTrayChanged" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <TextBlock Text="테마" VerticalAlignment="Center" Width="80" />
                        <ComboBox x:Name="ThemeCombo" Width="160" SelectionChanged="OnThemeChanged">
                            <ComboBoxItem Content="시스템" />
                            <ComboBoxItem Content="밝게" />
                            <ComboBoxItem Content="어둡게" />
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="기기" Style="{StaticResource Title}" Margin="0,0,0,12" />
                    <StackPanel>
                        <CheckBox x:Name="PairedOnlyCheckBox" Content="페어링한 내 기기만 표시" Margin="0,5"
                                  Checked="OnPairedOnlyChanged" Unchecked="OnPairedOnlyChanged" />
                        <TextBlock Text="이 PC에 페어링된 이어버드 계열만, 가장 가까운 것으로 표시해 주변 다른 사람 기기를 걸러냅니다."
                                   Style="{StaticResource Caption}" Margin="0,4,0,10" TextWrapping="Wrap" />
                        <CheckBox x:Name="ShowHiddenCheckBox" Content="숨긴 기기 표시" Margin="0,5"
                                  Checked="OnShowHiddenChanged" Unchecked="OnShowHiddenChanged" />
                        <TextBlock Text="고정 / 별칭 / 숨김은 대시보드의 기기 카드를 우클릭해 관리합니다."
                                   Style="{StaticResource Caption}" Margin="0,6,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="알림" Style="{StaticResource Title}" Margin="0,0,0,12" />
                    <StackPanel>
                        <CheckBox x:Name="NotifyEnabledCheckBox" Content="배터리 부족 알림 사용" Margin="0,5"
                                  Checked="OnNotifyEnabledChanged" Unchecked="OnNotifyEnabledChanged" />
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <TextBlock Text="이어버드 임계값" VerticalAlignment="Center" Width="120" />
                            <TextBox x:Name="EarbudThresholdBox" Width="60" Style="{StaticResource AppTextBox}"
                                     LostFocus="OnThresholdChanged" />
                            <TextBlock Text="%" VerticalAlignment="Center" Margin="6,0,0,0" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="케이스 임계값" VerticalAlignment="Center" Width="120" />
                            <TextBox x:Name="CaseThresholdBox" Width="60" Style="{StaticResource AppTextBox}"
                                     LostFocus="OnThresholdChanged" />
                            <TextBlock Text="%" VerticalAlignment="Center" Margin="6,0,0,0" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                            <CheckBox x:Name="SuppressRepeatCheckBox" Content="반복 알림 억제" VerticalAlignment="Center"
                                      Checked="OnSuppressRepeatChanged" Unchecked="OnSuppressRepeatChanged" />
                            <TextBox x:Name="SuppressMinutesBox" Width="52" Margin="12,0,0,0" Style="{StaticResource AppTextBox}"
                                     LostFocus="OnSuppressMinutesChanged" />
                            <TextBlock Text="분 이내 반복 억제" VerticalAlignment="Center" Margin="6,0,0,0" />
                        </StackPanel>
                        <CheckBox x:Name="QuietHoursCheckBox" Content="방해 금지 시간 사용" Margin="0,12,0,0"
                                  Checked="OnQuietHoursChanged" Unchecked="OnQuietHoursChanged" />
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="방해 금지 시간대" VerticalAlignment="Center" Width="120" />
                            <TextBox x:Name="QuietStartBox" Width="64" Style="{StaticResource AppTextBox}"
                                     LostFocus="OnQuietTimeChanged" />
                            <TextBlock Text="~" VerticalAlignment="Center" Margin="8,0,8,0" />
                            <TextBox x:Name="QuietEndBox" Width="64" Style="{StaticResource AppTextBox}"
                                     LostFocus="OnQuietTimeChanged" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="개인정보" Style="{StaticResource Title}" Margin="0,0,0,12" />
                    <StackPanel>
                        <CheckBox x:Name="MaskAddressesCheckBox" Content="진단에서 블루투스 주소 마스킹" Margin="0,5"
                                  Checked="OnMaskAddressesChanged" Unchecked="OnMaskAddressesChanged" />
                        <TextBlock Text="진단 내보내기에 포함되는 블루투스 주소를 가립니다."
                                   Style="{StaticResource Caption}" Margin="0,4,0,10" TextWrapping="Wrap" />
                        <StackPanel IsEnabled="False">
                            <CheckBox Content="네트워크 접근 (비활성 · 로컬 전용)" Margin="0,5" />
                            <CheckBox Content="사용 통계 수집 (비활성)" Margin="0,5" />
                        </StackPanel>
                        <TextBlock Text="이 앱은 로컬 전용입니다 — 네트워크·통계 항목은 항상 꺼져 있습니다."
                                   Style="{StaticResource Caption}" Margin="0,6,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="업데이트" Style="{StaticResource Title}" Margin="0,0,0,12" />
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Text="현재 버전" DockPanel.Dock="Left"
                                   Foreground="{DynamicResource InkMutedBrush}" />
                        <TextBlock x:Name="VersionText" HorizontalAlignment="Right" FontWeight="SemiBold" Text="—" />
                    </DockPanel>
                    <CheckBox x:Name="CheckUpdatesCheckBox" Content="시작 시 업데이트 확인" Margin="0,5"
                              Checked="OnUpdateCheckToggled" Unchecked="OnUpdateCheckToggled" />
                    <TextBlock Text="업데이트 확인은 GitHub에 연결하는 유일한 네트워크 사용입니다. 사용 통계·텔레메트리는 전송하지 않습니다."
                               Style="{StaticResource Caption}" Margin="0,4,0,12" TextWrapping="Wrap" />
                    <StackPanel Orientation="Horizontal">
                        <Button Content="지금 업데이트 확인" Style="{StaticResource ButtonUtility}"
                                Click="OnCheckUpdatesNow" />
                        <TextBlock x:Name="UpdateStatusText" VerticalAlignment="Center" Margin="12,0,0,0"
                                   FontSize="14" FontWeight="Medium" Visibility="Collapsed" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="진단" Style="{StaticResource Title}" Margin="0,0,0,12" />
                    <StackPanel>
                        <Button Content="진단 창 열기" Style="{StaticResource ButtonUtility}"
                                HorizontalAlignment="Left" Margin="0,4" Click="OnOpenDiagnostics" />
                        <Button Content="로그 폴더 열기" Style="{StaticResource ButtonUtility}"
                                HorizontalAlignment="Left" Margin="0,4" Click="OnOpenLogs" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Window>
