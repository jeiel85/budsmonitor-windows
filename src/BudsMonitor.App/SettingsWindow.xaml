<Window x:Class="BudsMonitor.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BudsMonitor.App"
        mc:Ignorable="d"
        Title="설정 - BudsMonitor"
        Height="560" Width="460"
        MinHeight="400" MinWidth="400"
        WindowStartupLocation="CenterScreen">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="설정" FontSize="20" FontWeight="SemiBold" />
            <TextBlock Text="아래 항목은 이후 구현 단계에서 활성화됩니다."
                       Foreground="#666666" Margin="0,4,0,12" TextWrapping="Wrap" />

            <GroupBox Header="일반" Padding="10" Margin="0,6">
                <StackPanel IsEnabled="False">
                    <CheckBox Content="Windows 시작 시 실행" Margin="0,4" />
                    <CheckBox Content="트레이로 최소화" IsChecked="True" Margin="0,4" />
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="테마" VerticalAlignment="Center" Width="80" />
                        <ComboBox Width="160" SelectedIndex="0">
                            <ComboBoxItem Content="시스템" />
                            <ComboBoxItem Content="밝게" />
                            <ComboBoxItem Content="어둡게" />
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="기기" Padding="10" Margin="0,6">
                <StackPanel IsEnabled="False">
                    <CheckBox Content="숨긴 기기 표시" Margin="0,4" />
                    <TextBlock Text="고정 / 별칭 / 숨김은 기기 카드에서 관리합니다." Margin="0,4" Foreground="#666666" />
                </StackPanel>
            </GroupBox>

            <GroupBox Header="알림" Padding="10" Margin="0,6">
                <StackPanel IsEnabled="False">
                    <CheckBox Content="배터리 부족 알림 사용" IsChecked="True" Margin="0,4" />
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="이어버드 임계값" VerticalAlignment="Center" Width="120" />
                        <TextBox Text="20" Width="60" />
                        <TextBlock Text="%" VerticalAlignment="Center" Margin="4,0,0,0" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4">
                        <TextBlock Text="케이스 임계값" VerticalAlignment="Center" Width="120" />
                        <TextBox Text="20" Width="60" />
                        <TextBlock Text="%" VerticalAlignment="Center" Margin="4,0,0,0" />
                    </StackPanel>
                    <CheckBox Content="방해 금지 시간 사용" Margin="0,4" />
                    <CheckBox Content="반복 알림 억제" IsChecked="True" Margin="0,4" />
                </StackPanel>
            </GroupBox>

            <GroupBox Header="개인정보" Padding="10" Margin="0,6">
                <StackPanel IsEnabled="False">
                    <CheckBox Content="네트워크 접근 (비활성 · 로컬 전용)" Margin="0,4" />
                    <CheckBox Content="사용 통계 수집 (비활성)" Margin="0,4" />
                    <CheckBox Content="진단에서 블루투스 주소 마스킹" IsChecked="True" Margin="0,4" />
                </StackPanel>
            </GroupBox>

            <GroupBox Header="진단" Padding="10" Margin="0,6">
                <StackPanel IsEnabled="False">
                    <Button Content="진단 번들 생성" HorizontalAlignment="Left" Padding="10,4" Margin="0,4" />
                    <Button Content="로그 폴더 열기" HorizontalAlignment="Left" Padding="10,4" Margin="0,4" />
                </StackPanel>
            </GroupBox>
        </StackPanel>
    </ScrollViewer>
</Window>
