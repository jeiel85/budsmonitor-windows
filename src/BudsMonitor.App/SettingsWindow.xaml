<Window x:Class="BudsMonitor.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BudsMonitor.App"
        mc:Ignorable="d"
        Title="설정 - BudsMonitor"
        Height="620" Width="480"
        MinHeight="440" MinWidth="440"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource CanvasSoftBrush}">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="24">
            <TextBlock Text="설정" Style="{StaticResource Heading2}" />
            <TextBlock Text="아래 항목은 이후 구현 단계에서 활성화됩니다."
                       Style="{StaticResource Caption}" Margin="0,4,0,20" TextWrapping="Wrap" />

            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="일반" Style="{StaticResource Title}" Margin="0,0,0,12" />
                    <StackPanel IsEnabled="False">
                        <CheckBox Content="Windows 시작 시 실행" Margin="0,5" />
                        <CheckBox Content="트레이로 최소화" IsChecked="True" Margin="0,5" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                        <TextBlock Text="테마" VerticalAlignment="Center" Width="80" />
                        <ComboBox x:Name="ThemeCombo" Width="160" SelectionChanged="OnThemeChanged">
                            <ComboBoxItem Content="시스템" />
                            <ComboBoxItem Content="밝게" />
                            <ComboBoxItem Content="어둡게" />
                        </ComboBox>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="기기" Style="{StaticResource Title}" Margin="0,0,0,12" />
                    <StackPanel>
                        <CheckBox x:Name="ShowHiddenCheckBox" Content="숨긴 기기 표시" Margin="0,5"
                                  Checked="OnShowHiddenChanged" Unchecked="OnShowHiddenChanged" />
                        <TextBlock Text="고정 / 별칭 / 숨김은 대시보드의 기기 카드를 우클릭해 관리합니다."
                                   Style="{StaticResource Caption}" Margin="0,6,0,0" TextWrapping="Wrap" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="알림" Style="{StaticResource Title}" Margin="0,0,0,12" />
                    <StackPanel IsEnabled="False">
                        <CheckBox Content="배터리 부족 알림 사용" IsChecked="True" Margin="0,5" />
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <TextBlock Text="이어버드 임계값" VerticalAlignment="Center" Width="120" />
                            <TextBox Text="20" Width="60" Style="{StaticResource AppTextBox}" />
                            <TextBlock Text="%" VerticalAlignment="Center" Margin="6,0,0,0" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <TextBlock Text="케이스 임계값" VerticalAlignment="Center" Width="120" />
                            <TextBox Text="20" Width="60" Style="{StaticResource AppTextBox}" />
                            <TextBlock Text="%" VerticalAlignment="Center" Margin="6,0,0,0" />
                        </StackPanel>
                        <CheckBox Content="방해 금지 시간 사용" Margin="0,10,0,0" />
                        <CheckBox Content="반복 알림 억제" IsChecked="True" Margin="0,5" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="개인정보" Style="{StaticResource Title}" Margin="0,0,0,12" />
                    <StackPanel IsEnabled="False">
                        <CheckBox Content="네트워크 접근 (비활성 · 로컬 전용)" Margin="0,5" />
                        <CheckBox Content="사용 통계 수집 (비활성)" Margin="0,5" />
                        <CheckBox Content="진단에서 블루투스 주소 마스킹" IsChecked="True" Margin="0,5" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="업데이트" Style="{StaticResource Title}" Margin="0,0,0,12" />
                    <DockPanel Margin="0,0,0,10">
                        <TextBlock Text="현재 버전" DockPanel.Dock="Left"
                                   Foreground="{DynamicResource InkMutedBrush}" />
                        <TextBlock x:Name="VersionText" HorizontalAlignment="Right" FontWeight="SemiBold" Text="—" />
                    </DockPanel>
                    <CheckBox x:Name="CheckUpdatesCheckBox" Content="시작 시 업데이트 확인" Margin="0,5"
                              Checked="OnUpdateCheckToggled" Unchecked="OnUpdateCheckToggled" />
                    <TextBlock Text="업데이트 확인은 GitHub에 연결하는 유일한 네트워크 사용입니다. 사용 통계·텔레메트리는 전송하지 않습니다."
                               Style="{StaticResource Caption}" Margin="0,4,0,12" TextWrapping="Wrap" />
                    <Button Content="지금 업데이트 확인" Style="{StaticResource ButtonUtility}"
                            HorizontalAlignment="Left" Click="OnCheckUpdatesNow" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Text="진단" Style="{StaticResource Title}" Margin="0,0,0,12" />
                    <StackPanel>
                        <Button Content="진단 창 열기" Style="{StaticResource ButtonUtility}"
                                HorizontalAlignment="Left" Margin="0,4" Click="OnOpenDiagnostics" />
                        <Button Content="로그 폴더 열기" Style="{StaticResource ButtonUtility}"
                                HorizontalAlignment="Left" Margin="0,4" Click="OnOpenLogs" />
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Window>
