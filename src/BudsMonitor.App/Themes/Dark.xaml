<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Notion-style dark palette -->
    <Color x:Key="PrimaryColor">#FF3B9DF7</Color>
    <Color x:Key="PrimaryActiveColor">#FF2E7DD0</Color>
    <Color x:Key="SecondaryColor">#FF8AA0E0</Color>
    <Color x:Key="OnPrimaryColor">#FFFFFFFF</Color>
    <Color x:Key="CanvasColor">#FF1A1A1A</Color>
    <Color x:Key="CanvasSoftColor">#FF191919</Color>
    <Color x:Key="SurfaceColor">#FF262626</Color>
    <Color x:Key="InkColor">#FFEBEBEB</Color>
    <Color x:Key="InkSecondaryColor">#FFB4B4B4</Color>
    <Color x:Key="InkMutedColor">#FF9B9B9B</Color>
    <Color x:Key="InkFaintColor">#FF6F6F6F</Color>
    <Color x:Key="HairlineColor">#FF373737</Color>
    <Color x:Key="AccentGreenColor">#FF4EC96A</Color>
    <Color x:Key="AccentOrangeColor">#FFFF8A50</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
    <SolidColorBrush x:Key="PrimaryActiveBrush" Color="{StaticResource PrimaryActiveColor}" />
    <SolidColorBrush x:Key="SecondaryBrush" Color="{StaticResource SecondaryColor}" />
    <SolidColorBrush x:Key="OnPrimaryBrush" Color="{StaticResource OnPrimaryColor}" />
    <SolidColorBrush x:Key="CanvasBrush" Color="{StaticResource CanvasColor}" />
    <SolidColorBrush x:Key="CanvasSoftBrush" Color="{StaticResource CanvasSoftColor}" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
    <SolidColorBrush x:Key="InkBrush" Color="{StaticResource InkColor}" />
    <SolidColorBrush x:Key="InkSecondaryBrush" Color="{StaticResource InkSecondaryColor}" />
    <SolidColorBrush x:Key="InkMutedBrush" Color="{StaticResource InkMutedColor}" />
    <SolidColorBrush x:Key="InkFaintBrush" Color="{StaticResource InkFaintColor}" />
    <SolidColorBrush x:Key="HairlineBrush" Color="{StaticResource HairlineColor}" />
    <SolidColorBrush x:Key="AccentGreenBrush" Color="{StaticResource AccentGreenColor}" />
    <SolidColorBrush x:Key="AccentOrangeBrush" Color="{StaticResource AccentOrangeColor}" />

</ResourceDictionary>
