<Window x:Class="BudsMonitor.App.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BudsMonitor.App"
        mc:Ignorable="d"
        Title="업데이트 - BudsMonitor"
        Height="540" Width="470"
        MinHeight="420" MinWidth="420"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource CanvasSoftBrush}">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="새 버전이 있습니다" Style="{StaticResource Heading2}" />
        <TextBlock Grid.Row="1" x:Name="VersionText" Style="{StaticResource Caption}"
                   Margin="0,4,0,14" TextWrapping="Wrap" />

        <Border Grid.Row="2" Style="{StaticResource Card}">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="NotesText" TextWrapping="Wrap"
                           Foreground="{DynamicResource InkMutedBrush}" LineHeight="20" />
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="3" Margin="0,16,0,0">
            <TextBlock x:Name="ErrorText" Foreground="#E5484D" TextWrapping="Wrap"
                       Margin="0,0,0,10" Visibility="Collapsed" />

            <Grid x:Name="ActionPanel">
                <Button Content="나중에" Style="{StaticResource ButtonUtility}"
                        HorizontalAlignment="Left" Click="Later_Click" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="이 버전 건너뛰기" Style="{StaticResource ButtonUtility}"
                            Margin="0,0,8,0" Click="Skip_Click" />
                    <Button x:Name="UpdateBtn" Content="지금 업데이트" Style="{StaticResource ButtonPrimary}"
                            Click="Update_Click" />
                </StackPanel>
            </Grid>

            <StackPanel x:Name="ProgressPanel" Visibility="Collapsed">
                <ProgressBar x:Name="ProgressBar" Height="8" Minimum="0" Maximum="100" />
                <TextBlock x:Name="StatusText" Style="{StaticResource Caption}" Margin="0,8,0,0" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
