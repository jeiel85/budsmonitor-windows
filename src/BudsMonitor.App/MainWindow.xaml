<Window x:Class="BudsMonitor.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BudsMonitor.App"
        mc:Ignorable="d"
        Title="BudsMonitor"
        Height="480" Width="420"
        MinHeight="360" MinWidth="360"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource CanvasSoftBrush}">
    <DockPanel>
        <!-- nav-bar: quiet white chrome with a hairline underline -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource HairlineBrush}"
                BorderThickness="0,0,0,1"
                Padding="20,14">
            <Grid>
                <TextBlock Text="BudsMonitor" Style="{StaticResource Title}" VerticalAlignment="Center" />
                <Button Content="설정" Style="{StaticResource ButtonUtility}"
                        HorizontalAlignment="Right" Click="OnSettingsClick" />
            </Grid>
        </Border>

        <!-- empty state on the warm canvas -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="28">
            <TextBlock Text="아직 감지된 이어버드가 없습니다."
                       Style="{StaticResource Title}"
                       TextWrapping="Wrap" MaxWidth="320"
                       HorizontalAlignment="Center" TextAlignment="Center" />
            <TextBlock Text="이어버드 케이스를 열거나 블루투스 오디오 기기를 연결하세요."
                       Style="{StaticResource Caption}"
                       Margin="0,10,0,0" TextWrapping="Wrap" MaxWidth="300"
                       HorizontalAlignment="Center" TextAlignment="Center" />
        </StackPanel>
    </DockPanel>
</Window>
